2- cat << 'EOF' > setup-users.sh
#!/bin/bash
KEY="key.pem"
USER="ubuntu"
SERVERS=(
"54.80.245.87"
"100.31.57.106"
)
for ip in "${SERVERS[@]}"; do
  echo "Connecting to $ip..."
  ssh -o StrictHostKeyChecking=no -i $KEY $USER@$ip << EOF2
set -e
sudo groupadd devops 2>/dev/null || true
sudo useradd -m rj 2>/dev/null || true
sudo useradd -m cj 2>/dev/null || true
sudo usermod -aG devops rj
sudo usermod -aG devops cj
id rj
id cj
EOF2
  if [ $? -eq 0 ]; then
    echo "Done on $ip"
  else
    echo "Failed on $ip"
  fi

  echo "------------------------------"
done
EOF
